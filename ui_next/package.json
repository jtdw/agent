{
  "name": "gis-agent-web-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "test": "node --test \"tests/*.test.mjs\"",
    "test:analysis-model-results": "node tests/analysisModelResults.test.mjs",
    "test:layer-policy": "node tests/mapLayerPolicy.test.mjs",
    "test:local-library": "node tests/localLibraryFilters.test.mjs",
    "test:map-upgrades": "node tests/mapUpgrades.test.mjs",
    "test:research-workflow": "node tests/researchWorkflow.test.mjs",
    "test:analysis-panel": "node tests/analysisPanelData.test.mjs",
    "test:chat-message-content": "node tests/chatMessageContent.test.mjs",
    "test:chat-panel-experience": "node tests/chatPanelExperience.test.mjs",
    "test:chat-persistence": "node tests/chatPersistence.test.mjs",
    "test:product-console": "node tests/productConsoleData.test.mjs",
    "test:task-outcome-experience": "node tests/taskOutcomeExperience.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test -c playwright.real-backend.config.ts",
    "lint": "tsc -b --pretty false",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "clsx": "2.1.1",
    "framer-motion": "12.40.0",
    "lucide-react": "1.16.0",
    "maplibre-gl": "5.24.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-is": "^19.2.6",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.6.0",
    "typescript": "6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/geojson": "^7946.0.16",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "^4.1.17"
  },
  "description": "Web-only React UI for GIS Agent. Electron and desktop entrypoints removed."
}
