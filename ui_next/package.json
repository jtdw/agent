{
  "name": "gis-agent-web-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "test:layer-policy": "node tests/mapLayerPolicy.test.mjs",
    "test:local-library": "node tests/localLibraryFilters.test.mjs",
    "test:map-upgrades": "node tests/mapUpgrades.test.mjs",
    "test:research-workflow": "node tests/researchWorkflow.test.mjs",
    "test:analysis-panel": "node tests/analysisPanelData.test.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "clsx": "latest",
    "tailwind-merge": "latest",
    "maplibre-gl": "latest",
    "recharts": "latest"
  },
  "devDependencies": {
    "tailwindcss": "^4.1.17",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  },
  "description": "Web-only React UI for GIS Agent. Electron and desktop entrypoints removed."
}
