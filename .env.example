# LLM provider configuration. Do not put real keys in Git.
# Supported providers: zai, openai, fake. fake is for tests/dry-run only.
LLM_PROVIDER=zai
LLM_MODEL=glm-4.7
LLM_API_KEY_ENV=ZAI_API_KEY
LLM_BASE_URL=https://api.z.ai/api/paas/v4/
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.1
ENABLE_LLM_INTENT_CLASSIFIER=0
FALLBACK_TO_RULE_CLASSIFIER=1

# Backward-compatible z.ai variables. Existing deployments may keep using these.
ZAI_API_KEY=
ZAI_MODEL=glm-4.7
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# OpenAI-compatible provider example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY_ENV=OPENAI_API_KEY
OPENAI_API_KEY=
GIS_AGENT_WORKDIR=./workspace
GIS_AGENT_ENV=development
GIS_AGENT_TEMPERATURE=0.1
GIS_AGENT_THEME=light

ZAI_SUPPORTED_MODELS=glm-4.5-air,glm-4.7,glm-4.1v-thinking-flashx,glm-4.6v
# 天地图：用于网页底图、注记、地名搜索、逆地理编码和数据 API 辅助查询。
# 浏览器端地图 Key 会被前端使用，请在天地图控制台限制允许域名/Referer。
TIANDITU_TOKEN=
TIANDITU_DEFAULT_BASEMAP=vec
TIANDITU_ENABLE_WEB_SERVICE=1
TIANDITU_ENABLE_DATA_API=1

# 国内数据源账号（可选；不要把真实账号密码提交到代码仓库）
# 第一版推荐使用“手动登录保存 Cookie”，所以这些账号密码可以先不填。
GSCLOUD_USERNAME=
GSCLOUD_PASSWORD=
CMA_USERNAME=
CMA_PASSWORD=
GEODATA_USERNAME=
GEODATA_PASSWORD=
RESDC_USERNAME=
RESDC_PASSWORD=

# 国内数据源浏览器下载捕获默认建议：本机测试用 headless=false。
DOMESTIC_DOWNLOAD_TIMEOUT_SECONDS=900

# 商业化模块：凭据加密密钥。生产环境必须设置到系统环境变量或服务器密钥管理器，不要提交到代码仓库。
# 可让智能体调用 generate_commercial_secret_key 生成。
APP_SECRET_KEY=
GIS_AGENT_ALLOW_WORKSPACE_SECRET_FILE=1
GIS_AGENT_ADMIN_TOKEN=
GIS_AGENT_ENABLE_MOCK_PAYMENT=0
GIS_AGENT_COOKIE_SECURE=0
GIS_AGENT_SESSION_COOKIE_MAX_AGE=604800

# 商业版默认设置
COMMERCIAL_DEFAULT_PLAN=basic
COMMERCIAL_RESULT_RETENTION_DAYS=7

# 账号/支付中心说明：
# 普通用户：注册后绑定自己的地理空间数据云账号，任务使用 account_mode=own。
# 付费用户：模拟支付成功后获得平台账号额度，任务使用 account_mode=platform。
# APP_SECRET_KEY 用于加密用户数据源账号和平台账号，生产环境必须使用固定密钥。

# Web 端账号/会员联通
# Web 与桌面端共用 GIS_AGENT_WORKDIR 下的 workspace/commercial.db；注册、登录、支付、下载额度在两端同步。

# 后台平台账号池：推荐只放到服务器环境变量，不放进前台界面或代码仓库。
# 填写后，Web 启动时会自动写入/更新 platform_accounts，前台会员只选择“使用平台账号池”。
GSCLOUD_PLATFORM_USERNAME=
GSCLOUD_PLATFORM_PASSWORD=
GSCLOUD_PLATFORM_STORAGE_STATE=
GSCLOUD_PLATFORM_LABEL=后台地理空间数据云账号
GSCLOUD_PLATFORM_DAILY_LIMIT=50
GSCLOUD_PLATFORM_MONTHLY_LIMIT=1000

# 管理员调试开关：默认不显示平台账号明文配置面板。只在本地/内网管理时临时打开。
ENABLE_PLATFORM_ACCOUNT_ADMIN=0

# 本地文件库：放置中国行政区划、降雨、DEM、遥感产品等初始基础数据。
# 默认位于 GIS_AGENT_WORKDIR/local_library；如要固定到项目目录或外置硬盘，可改成绝对路径。
GIS_AGENT_LOCAL_LIBRARY_DIR=./workspace/local_library
GIS_AGENT_ENABLE_MODELING_ADVISOR="1"

# LangChain / Agent Runtime V2 改造开关
# 说明：以下配置用于新的 runtime 边界、planner/coordinator 诊断、离线评估和后续灰度切换。
# 默认保持关闭或 legacy，不会改变现有对话、工具执行和前端行为。
# 如果后续不使用 runtime v2 / RAG / eval，可以删除本段；如果要启用，请先在本地或 staging 验证。

# 是否启用 Agent Runtime V2 外壳。0=关闭，1=启用。
GIS_AGENT_RUNTIME_V2=0

# Runtime 模式：legacy / shadow / active。
# legacy：旧路径；shadow：只做诊断/旁路计划；active：参与 active planner，但仍需下面的二次确认开关。
GIS_AGENT_RUNTIME_MODE=legacy

# active 模式二次确认开关。只有 GIS_AGENT_RUNTIME_V2=1、GIS_AGENT_RUNTIME_MODE=active、
# 且本项=1 时，active cutover 才真正生效；否则会自动降级为 shadow/legacy。
GIS_AGENT_RUNTIME_ALLOW_ACTIVE_CUTOVER=0

# Agent Runtime active 暴露策略（只读诊断，不改变真实流量路由）。
# local=本地观察；staging=小比例验证；production=生产，必须额外打开生产覆盖开关。
GIS_AGENT_RUNTIME_EXPOSURE_ENV=local

# 计划暴露比例，0 表示仅观察不放量。staging 初始建议不超过 10。
GIS_AGENT_RUNTIME_EXPOSURE_PERCENT=0

# 是否强制按暴露比例做真实请求路由。0=不接管真实路由；1=只有命中暴露比例的请求才走 active runtime，其余回退 legacy。
GIS_AGENT_RUNTIME_ENFORCE_EXPOSURE_ROUTING=0

# 暴露分桶盐值。staging/production 固定后不要频繁修改，否则同一用户/会话的命中结果会变化；不是密钥，不要放 token。
GIS_AGENT_RUNTIME_EXPOSURE_SALT=agent-runtime-exposure-v1

# 回滚开关。设为 1 时，即使 active/smoke 通过，也会阻止用户暴露资格。
GIS_AGENT_RUNTIME_ROLLBACK=0

# deterministic active smoke 报告路径。报告需通过且 ready_for_next_phase=true 才具备暴露资格。
GIS_AGENT_RUNTIME_SMOKE_REPORT=outputs/agent_runtime_service_active_smoke_guard.json

# 是否要求 LLM coordinator smoke 报告也通过。默认不要求，避免 CI/默认环境消耗 LLM token。
GIS_AGENT_RUNTIME_REQUIRE_LLM_SMOKE=0

# 可选：逗号分隔的 LLM coordinator smoke 报告路径，仅 GIS_AGENT_RUNTIME_REQUIRE_LLM_SMOKE=1 时作为门禁。
GIS_AGENT_RUNTIME_LLM_SMOKE_REPORTS=outputs/agent_runtime_service_llm_coordinator_describe_guard.json,outputs/agent_runtime_service_llm_coordinator_map_guard.json,outputs/agent_runtime_service_llm_coordinator_table_points_guard.json,outputs/agent_runtime_service_llm_coordinator_raster_clip_guard.json,outputs/agent_runtime_service_llm_coordinator_vector_clip_map_guard.json,outputs/agent_runtime_service_llm_coordinator_table_points_map_guard.json

# 生产暴露额外确认。只有 production 环境需要；默认必须保持 0。
GIS_AGENT_RUNTIME_ALLOW_PRODUCTION_EXPOSURE=0

# 旧 LLM planner shadow 开关。通常 runtime v2 shadow/active 已能接管诊断；
# 保留此项是为了兼容旧 shadow planner 观测流程。
GIS_AGENT_ENABLE_LLM_PLANNER_SHADOW=0

# Vector RAG 上下文增强开关。0=不把 vector RAG 检索结果注入对话上下文。
GIS_AGENT_ENABLE_VECTOR_RAG_CONTEXT=0

# Vector RAG 后端：local 使用本地 TF-IDF scaffold；api 使用 OpenAI-compatible embedding + JSON 持久化 store。
GIS_AGENT_VECTOR_RAG_BACKEND=local

# Vector RAG 持久化索引位置。建议放在 workspace 内，便于清理和迁移。
GIS_AGENT_VECTOR_RAG_STORE=./workspace/agent_runtime/vector_rag.json

# Embedding API 配置。仅 GIS_AGENT_VECTOR_RAG_BACKEND=api 时需要。
# 不要把真实 API Key 提交到代码仓库；生产环境建议使用服务器环境变量或密钥管理器。
GIS_AGENT_EMBEDDING_PROVIDER=openai
GIS_AGENT_EMBEDDING_MODEL=text-embedding-3-small
GIS_AGENT_EMBEDDING_BASE_URL=https://api.openai.com/v1
GIS_AGENT_EMBEDDING_TIMEOUT=30
GIS_AGENT_EMBEDDING_API_KEY=
