# LLM provider configuration. Do not put real keys in Git.
# Supported providers: zai, openai, fake. fake is for tests/dry-run only.
LLM_PROVIDER=zai
LLM_MODEL=glm-4.5-air
LLM_API_KEY_ENV=ZAI_API_KEY
LLM_BASE_URL=https://api.z.ai/api/paas/v4/
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.1
ENABLE_LLM_INTENT_CLASSIFIER=0
FALLBACK_TO_RULE_CLASSIFIER=1

# Backward-compatible z.ai variables. Existing deployments may keep using these.
ZAI_API_KEY=
ZAI_MODEL=glm-4.5-air
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# OpenAI-compatible provider example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY_ENV=OPENAI_API_KEY
OPENAI_API_KEY=
GIS_AGENT_WORKDIR=./workspace
GIS_AGENT_ENV=development
GIS_AGENT_TEMPERATURE=0.1
GIS_AGENT_THEME=light

ZAI_SUPPORTED_MODELS=glm-4.5-air,glm-4.7,glm-4.1v-thinking-flashx,glm-4.6v
# 天地图：用于网页底图、注记、地名搜索、逆地理编码和数据 API 辅助查询。
# 浏览器端地图 Key 会被前端使用，请在天地图控制台限制允许域名/Referer。
TIANDITU_TOKEN=
TIANDITU_DEFAULT_BASEMAP=vec
TIANDITU_ENABLE_WEB_SERVICE=1
TIANDITU_ENABLE_DATA_API=1

# 国内数据源账号（可选；不要把真实账号密码提交到代码仓库）
# 第一版推荐使用“手动登录保存 Cookie”，所以这些账号密码可以先不填。
GSCLOUD_USERNAME=
GSCLOUD_PASSWORD=
CMA_USERNAME=
CMA_PASSWORD=
GEODATA_USERNAME=
GEODATA_PASSWORD=
RESDC_USERNAME=
RESDC_PASSWORD=

# 国内数据源浏览器下载捕获默认建议：本机测试用 headless=false。
DOMESTIC_DOWNLOAD_TIMEOUT_SECONDS=900

# 商业化模块：凭据加密密钥。生产环境必须设置到系统环境变量或服务器密钥管理器，不要提交到代码仓库。
# 可让智能体调用 generate_commercial_secret_key 生成。
APP_SECRET_KEY=
GIS_AGENT_ALLOW_WORKSPACE_SECRET_FILE=1
GIS_AGENT_ADMIN_TOKEN=
GIS_AGENT_ENABLE_MOCK_PAYMENT=0
GIS_AGENT_COOKIE_SECURE=0
GIS_AGENT_SESSION_COOKIE_MAX_AGE=604800

# 商业版默认设置
COMMERCIAL_DEFAULT_PLAN=basic
COMMERCIAL_RESULT_RETENTION_DAYS=7

# 账号/支付中心说明：
# 普通用户：注册后绑定自己的地理空间数据云账号，任务使用 account_mode=own。
# 付费用户：模拟支付成功后获得平台账号额度，任务使用 account_mode=platform。
# APP_SECRET_KEY 用于加密用户数据源账号和平台账号，生产环境必须使用固定密钥。

# Web 端账号/会员联通
# Web 与桌面端共用 GIS_AGENT_WORKDIR 下的 workspace/commercial.db；注册、登录、支付、下载额度在两端同步。

# 后台平台账号池：推荐只放到服务器环境变量，不放进前台界面或代码仓库。
# 填写后，Web 启动时会自动写入/更新 platform_accounts，前台会员只选择“使用平台账号池”。
GSCLOUD_PLATFORM_USERNAME=
GSCLOUD_PLATFORM_PASSWORD=
GSCLOUD_PLATFORM_STORAGE_STATE=
GSCLOUD_PLATFORM_LABEL=后台地理空间数据云账号
GSCLOUD_PLATFORM_DAILY_LIMIT=50
GSCLOUD_PLATFORM_MONTHLY_LIMIT=1000

# 管理员调试开关：默认不显示平台账号明文配置面板。只在本地/内网管理时临时打开。
ENABLE_PLATFORM_ACCOUNT_ADMIN=0

# 本地文件库：放置中国行政区划、降雨、DEM、遥感产品等初始基础数据。
# 默认位于 GIS_AGENT_WORKDIR/local_library；如要固定到项目目录或外置硬盘，可改成绝对路径。
GIS_AGENT_LOCAL_LIBRARY_DIR=./workspace/local_library
